# Sanjaya base
SANJAYA_BASE_URL=https://sanjaya.atimotors.com

# Credentials for /api/v1/master_fm/user/login
SANJAYA_USERNAME=ati_support
SANJAYA_PASSWORD=1234
SANJAYA_SOURCE=cli

# Defaults (avoid hardcoding Nagpur in code; set them here)
SANJAYA_DEFAULT_CLIENT=ceat-nagpur
SANJAYA_DEFAULT_FLEET=CEAT-Nagpur-North-Plant
SANJAYA_DEFAULT_TZ=Asia/Kolkata

# Ollama LLM for NLU (falls back to heuristics if unavailable)
# Running locally (outside Docker): http://localhost:11434
# Running inside Docker Compose:    http://ollama:11434
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b-instruct
OLLAMA_ENABLE=1
